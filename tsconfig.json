{
  "compilerOptions": {
    "module": "node16",
    "target": "es2022",
    "lib": ["es2022"],
    "outDir": "out",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "declaration": true,
    "moduleResolution": "node16"
  },
  "include": ["src"],
  "exclude": ["node_modules", "out"]
}
